# =============================================================================
# InnovateSphere V2 — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# RAG_DATABASE_URL=  # Legacy, only needed if using separate RAG database

# --- Security ---
SECRET_KEY=change-me-to-a-random-string
JWT_SECRET=change-me-to-a-random-string
JWT_ALGO=HS256
JWT_EXP_SECONDS=3600

# --- LLM Provider ---
LLM_PROVIDER=ollama
LLM_MODEL_NAME=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=           # Only if using openai provider

# --- LLM Timeouts & Retries (production mode) ---
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=4
LLM_BACKOFF_BASE_SECONDS=0.5
LLM_BACKOFF_MAX_SECONDS=30.0
OLLAMA_HEALTH_TIMEOUT=2.0
OLLAMA_STARTUP_TIMEOUT=5.0
LLM_STARTUP_HARD_FAIL=true

# --- LLM Fallback ---
LLM_FALLBACK_ENABLED=false
LLM_FALLBACK_PROVIDER=openai

# --- Pipeline Mode (pick ONE) ---
# HYBRID_MODE: 2-pass LLM + heuristic retrieval — recommended for 15GB CPU
# DEMO_MODE:   1-pass LLM, no real retrieval/novelty — quick testing
# Neither:     Full 4-pass production pipeline
HYBRID_MODE=true
DEMO_MODE=false

# --- Hybrid Mode Settings ---
HYBRID_LLM_TIMEOUT_SECONDS=90
HYBRID_LLM_MAX_RETRIES=2
HYBRID_MAX_SOURCES_FOR_PROMPT=5

# --- Demo Mode Settings ---
DEMO_LLM_TIMEOUT_SECONDS=45
DEMO_LLM_MAX_RETRIES=1

# --- Embeddings ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Generation Constraints ---
MAX_SOURCES_FOR_LLM=8
MIN_EVIDENCE_REQUIRED=1

# --- Abuse Protection ---
MAX_GENERATION_REQUESTS_PER_MIN=6
ABUSE_WINDOW_SECONDS=60
AUTO_BLOCK_AFTER_INFRACTIONS=5

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Logging ---
LOG_LEVEL=INFO

# --- Test Credentials (used by scripts/*.py test runners) ---
TEST_USER_EMAIL=test@test.com
TEST_USER_PASSWORD=change-me
TEST_ADMIN_EMAIL=admin1@example.com
TEST_ADMIN_PASSWORD=change-me

# --- AI Pipeline ---
DEFAULT_AI_PIPELINE_VERSION=v2-hybrid
ENABLE_AI_PIPELINES=true

# --- Frontend (set in frontend/.env or shell) ---
# REACT_APP_API_URL=http://localhost:5000/api
